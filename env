# RCA Platform v2 - Environment Configuration

# -- Splunk ---------------------------------------------------------------
# REST API (querying logs for RCA) - fill in your credentials below
SPLUNK_REST_URL=https://<your-splunk-host>:8089
SPLUNK_USERNAME=<your-splunk-userid>
SPLUNK_PASSWORD=<your-splunk-password>
SPLUNK_INDEX=<your-index-name>

# SSL verification for REST API calls:
#   false          -> skip verify (self-signed / internal cert, most common)
#   true           -> verify with system CA bundle
#   C:/path/to.pem -> verify with a specific CA bundle file
SPLUNK_SSL_VERIFY=false

# HEC (only needed if writing logs into Splunk - not required for read-only RCA)
SPLUNK_HEC_URL=http://<your-splunk-host>:8088/services/collector/event
SPLUNK_HEC_TOKEN=<your-hec-token-if-any>

# -- pgvector -------------------------------------------------------------
PGVECTOR_USER=rca
PGVECTOR_PASSWORD=rca
PGVECTOR_DB=rca_db
PGVECTOR_DSN=postgresql://rca:rca@localhost:5432/rca_db

# -- LLM - Corporate / Bearer-token endpoint ------------------------------
# Set LLM_AUTH_TOKEN to switch to Bearer-token mode.
# Leave it empty to fall back to LM Studio / API-key mode.
LLM_BASE_URL=https://r2d2-c3p8-icg-msst-genaihub-178909.apps.namicg39023u.ecs.dyn.nsroot.net/stellar/v1
LLM_API_KEY=DUMMY
LLM_AUTH_TOKEN=<paste your Bearer token here>
LLM_CHAT_MODEL=Meta-llama-3.3-70B-Instruct

# Path to your internal CA chain PEM (needed for corporate SSL)
LLM_SSL_CERT_FILE=C:/path/to/pityInternalCAChain_PROD.pem

# -- Embedding model ------------------------------------------------------
EMBED_MODEL=gte-large-en-v1.5
EMBED_DIMS=1024

# -- Loki -----------------------------------------------------------------
LOKI_URL=http://localhost:3100

# -- RCA tuning -----------------------------------------------------------
KNOWN_ISSUE_DISTANCE_THRESHOLD=0.3
BATCH_THREADS=8
LOG_CHUNK_SIZE=500

# -- Log generator --------------------------------------------------------
TARGET_MB_PER_HOUR=1024
WORKER_THREADS=4
BATCH_SIZE=100
APP_IDS=app-alpha,app-beta,app-gamma,app-delta,app-epsilon
