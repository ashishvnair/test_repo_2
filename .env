# ═══════════════════════════════════════════════════════════════════════════════
# RCA Platform v2 — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Splunk ─────────────────────────────────────────────────────────────────────
# The HEC token must match the token in infra/splunk/inputs.conf.
# Splunk Web is on host port 8080 (internally uses port 8000).
SPLUNK_HEC_TOKEN=rca-hec-token-00000000-0000-0000-0000-000000000001
SPLUNK_PASSWORD=changeme
SPLUNK_HEC_URL=http://localhost:8088/services/collector/event
SPLUNK_REST_URL=https://localhost:8089
SPLUNK_INDEX=rca_logs

# ── pgvector (PostgreSQL 16) ────────────────────────────────────────────────────
# Used both as the vector DB (rca_reports table) and app registry (apps table).
PGVECTOR_USER=rca
PGVECTOR_PASSWORD=rca
PGVECTOR_DB=rca_db
PGVECTOR_DSN=postgresql://rca:rca@localhost:5432/rca_db

# ── LM Studio (local LLM, runs on host machine) ────────────────────────────────
# LM Studio must be running before starting the stack.
# The containers reach host port 1234 via host.docker.internal.
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_API_KEY=lm-studio
LLM_CHAT_MODEL=meta-llama-3.1-8b-instruct@q5_k_m
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
# Nomic embed text v1.5 (LM Studio default) produces 768-dimensional vectors.
EMBED_DIMS=768

# ── Loki (secondary log store) ─────────────────────────────────────────────────
LOKI_URL=http://localhost:3100

# ── RCA tuning ─────────────────────────────────────────────────────────────────
# Cosine distance threshold for classifying an error as "known" (0=identical).
# Same value as the old ChromaDB setup — no change in behaviour.
KNOWN_ISSUE_DISTANCE_THRESHOLD=0.3
# Number of threads in the batch processor (one thread = one log chunk).
BATCH_THREADS=8
# Log lines per chunk in the batch processor.
LOG_CHUNK_SIZE=500

# ── Log generator ──────────────────────────────────────────────────────────────
# Target throughput in MB/hr. At 350 bytes/event → ~1024 MB/hr = ~813 events/sec.
TARGET_MB_PER_HOUR=1024
# Worker threads (each handles ~MB/hr / WORKER_THREADS).
WORKER_THREADS=4
# Events per HEC POST batch (keep-alive session per thread).
BATCH_SIZE=100
# Comma-separated list of app IDs the generator distributes logs across.
APP_IDS=app-alpha,app-beta,app-gamma,app-delta,app-epsilon
