# RCA Platform - Environment Configuration

# -- pgvector (PostgreSQL) ------------------------------------------------
PGVECTOR_DSN=postgresql://rca:rca@localhost:5432/rca_db

# -- LLM - Corporate / Bearer-token endpoint ------------------------------
LLM_BASE_URL=https://<your-llm-endpoint>/v1
LLM_API_KEY=DUMMY
LLM_AUTH_TOKEN=<paste your Bearer token here>
LLM_CHAT_MODEL=Meta-llama-3.3-70B-Instruct
LLM_SSL_CERT_FILE=C:/path/to/pityInternalCAChain_PROD.pem

# -- Embedding model ------------------------------------------------------
EMBED_MODEL=gte-large-en-v1.5
EMBED_DIMS=1024

# -- RCA tuning -----------------------------------------------------------
# Cosine distance threshold: report is "known issue" below this value (0=identical)
KNOWN_ISSUE_DISTANCE_THRESHOLD=0.3
# Composite similarity score (0-1) required to surface a stored report in UI
SIMILARITY_THRESHOLD=0.60
# Batch processor worker threads and log lines per chunk
BATCH_THREADS=8
LOG_CHUNK_SIZE=500
